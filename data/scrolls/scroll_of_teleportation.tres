outcomes = {"crit_good": {"description": "Teleport to a Random Space closer to the Amulet Game by up to 3 Spaces.", "effects": [{"op": "teleport", "dir": "closer", "max_steps": 3}]}, "good": {"description": "Teleport to a Random Space with the same distance from the Amulet Game.", "effects": [{"op": "teleport", "dir": "same"}]}, "bad": {"description": "Teleport to a Random Space farther away from the Amulet Game by up to 3 Spaces.", "effects": [{"op": "teleport", "dir": "farther", "max_steps": 3}]}, "crit_bad": {"description": "Teleport to a completely Random Space.", "effects": [{"op": "teleport", "dir": "random"}]}}
