[gd_resource type="Resource" script_class="EncounterData" load_steps=3 format=3 uid="uid://encounter_deal_with_the_devil"]

[ext_resource type="Script" path="res://scripts/resources/EncounterData.gd" id="1_enc"]
[ext_resource type="Texture2D" path="res://images/encounters/deal-with-the-devil.png" id="2_img"]

[resource]
script = ExtResource("1_enc")
id = &"deal_with_the_devil"
display_name = "Deal with the Devil"
type = "Deal"
rarity = "Uncommon"
description = "Pick any of 3 Random Evil Items, but lose health based on rarity and gain a Random Curse for each Item taken."
npc = "Satan"
reference = "The Binding of Isaac"
img = "deal-with-the-devil"
effects = [{"op": "offer_items", "tag": "evil", "count": 3, "pick": "any"}, {"op": "per_item", "effect": {"op": "lose_hp_pct", "by_rarity": [10, 15, 20, 25, 30]}}, {"op": "per_item", "effect": {"op": "add_curse", "count": 1}}]
requirement = "Trigger a Curse in the last Game Cleared"
requirement_effect = [{"field": "last_game.curses_triggered", "cmp": ">=", "value": 1}]
