script = ExtResource("1")
id = &"crit_chance"
display_name = "Crit Chance"
description = "Base critical-hit chance. Per-hit roll is max(0, 2 x Luck) + Crit Chance, capped at 100%. A crit deals bonus damage equal to Crit Damage. Surfaced in combat as the Crit Chance Up status only while above 0."
